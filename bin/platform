#!/usr/bin/env bash
# ABOUTME: Platform CLI - main entry point for infrastructure provisioning
# ABOUTME: Provides intuitive commands with validation, cost estimation, and GitOps integration

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source secure validation functions
# shellcheck source=./platform-validation.sh
source "${SCRIPT_DIR}/platform-validation.sh"

# Version
VERSION="1.0.0"

# Helper functions
info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

success() {
    echo -e "${GREEN}✓${NC} $1"
}

error() {
    echo -e "${RED}✗${NC} $1" >&2
}

warn() {
    echo -e "${YELLOW}⚠${NC} $1"
}

# Show usage
usage() {
    cat << EOF
${PURPLE}Platform CLI${NC} - Backend-First IDP Infrastructure Management
Version: ${VERSION}

${CYAN}Usage:${NC}
  platform <command> [options]

${CYAN}Commands:${NC}
  ${GREEN}list${NC}              List available infrastructure types
  ${GREEN}create${NC}            Create new infrastructure claim
  ${GREEN}status${NC}            Check status of provisioned resources
  ${GREEN}cost${NC}              Estimate costs for infrastructure
  ${GREEN}validate${NC}          Validate a claim file
  ${GREEN}connect${NC}           Get connection details for a resource
  ${GREEN}delete${NC}            Delete infrastructure claim
  ${GREEN}promote${NC}           Promote claim to another environment

${CYAN}Examples:${NC}
  # List available infrastructure types
  platform list

  # Create a PostgreSQL database
  platform create postgres my-db --size=small --env=dev

  # Check status of a resource
  platform status postgres my-db --env=dev

  # Estimate costs
  platform cost postgres --size=medium --env=staging

  # Validate a claim file
  platform validate environments/dev/my-db.yaml

  # Get connection details
  platform connect postgres my-db --env=dev

  # Promote to staging
  platform promote postgres my-db --from=dev --to=staging

${CYAN}Global Options:${NC}
  -h, --help         Show this help message
  -v, --version      Show version information
  --debug            Enable debug output

${CYAN}Learn More:${NC}
  Documentation: docs/
  Examples: examples/
  GitHub: github.com/peopleforrester/2026_Kubecon_Europe_CNCF_Portal_Fatigue_IDP_Tutorial

EOF
}

# Version info
version() {
    echo "Platform CLI version ${VERSION}"
    echo "Backend-First IDP for KubeCon Europe 2026"
}

# Main command router
main() {
    # No arguments - show usage
    if [[ $# -eq 0 ]]; then
        usage
        exit 0
    fi

    # SECURITY: Command routing uses whitelist approach
    # Only explicit commands are allowed, unknown commands are rejected
    # All user input validation is performed in the delegated scripts
    case "${1:-}" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            version
            exit 0
            ;;
        list)
            shift
            "${SCRIPT_DIR}/platform-list" "$@"
            ;;
        create)
            shift
            "${SCRIPT_DIR}/platform-create" "$@"
            ;;
        status)
            shift
            "${SCRIPT_DIR}/platform-status" "$@"
            ;;
        cost)
            shift
            "${SCRIPT_DIR}/platform-cost" "$@"
            ;;
        validate)
            shift
            "${SCRIPT_DIR}/platform-validate" "$@"
            ;;
        connect)
            shift
            "${SCRIPT_DIR}/platform-connect" "$@"
            ;;
        delete)
            shift
            "${SCRIPT_DIR}/platform-delete" "$@"
            ;;
        promote)
            shift
            "${SCRIPT_DIR}/platform-promote" "$@"
            ;;
        *)
            error "Unknown command: ${1}"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
