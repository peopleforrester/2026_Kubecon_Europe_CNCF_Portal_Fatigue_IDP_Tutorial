#!/usr/bin/env bash
# ABOUTME: Platform cost command - estimate infrastructure costs
# ABOUTME: Provides detailed cost breakdowns and comparisons

set -euo pipefail

# Source shared boilerplate (colors, dirs, helpers, validation)
# shellcheck source=./platform-common.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/platform-common.sh"

usage() {
    cat << EOF
Usage: platform cost <type> [options]

Estimate monthly costs for infrastructure.

${CYAN}Options:${NC}
  --size=SIZE         Instance size (small, medium, large)
  --multi-az          Include Multi-AZ costs (PostgreSQL)
  --nodes=N           Number of nodes (Redis)
  --storage=GB        Storage amount in GB (PostgreSQL)
  --compare           Show cost comparison across sizes

${CYAN}Examples:${NC}
  # Estimate PostgreSQL costs
  platform cost postgres --size=medium

  # Estimate with Multi-AZ
  platform cost postgres --size=large --multi-az

  # Compare Redis sizes
  platform cost redis --compare

  # Estimate with storage
  platform cost postgres --size=medium --storage=100

EOF
}

# Cost table for PostgreSQL
cost_postgres() {
    local size="${1:-}"
    local multi_az="${2:-false}"
    local storage="${3:-20}"
    local compare="${4:-false}"

    if [[ "$compare" == "true" ]]; then
        cat << EOF
${PURPLE}PostgreSQL Cost Comparison${NC}

${CYAN}Single-AZ Instances:${NC}
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ Size    в”Ӯ Instance     в”Ӯ Monthly Cost   в”Ӯ Best For        в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ small   в”Ӯ db.t3.micro  в”Ӯ ~\$15/month    в”Ӯ Dev/Test        в”Ӯ
в”Ӯ medium  в”Ӯ db.t3.small  в”Ӯ ~\$30/month    в”Ӯ Staging         в”Ӯ
в”Ӯ large   в”Ӯ db.t3.medium в”Ӯ ~\$60/month    в”Ӯ Small Prod      в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

${CYAN}Multi-AZ Instances (2x cost):${NC}
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ Size    в”Ӯ Instance     в”Ӯ Monthly Cost   в”Ӯ Best For        в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ small   в”Ӯ db.t3.micro  в”Ӯ ~\$30/month    в”Ӯ Critical Dev    в”Ӯ
в”Ӯ medium  в”Ӯ db.t3.small  в”Ӯ ~\$60/month    в”Ӯ Production      в”Ӯ
в”Ӯ large   в”Ӯ db.t3.medium в”Ӯ ~\$120/month   в”Ӯ High-Avail Prod в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

${CYAN}Additional Costs:${NC}
вҖў Storage: \$0.115/GB/month (first 20GB included)
вҖў Backups: Included (automated daily)
вҖў Data Transfer: \$0.09/GB outbound

EOF
        return
    fi

    local instance_cost=0
    local instance_type=""

    case "$size" in
        small)
            instance_cost=15
            instance_type="db.t3.micro"
            ;;
        medium)
            instance_cost=30
            instance_type="db.t3.small"
            ;;
        large)
            instance_cost=60
            instance_type="db.t3.medium"
            ;;
        *)
            echo "Invalid size. Use: small, medium, large"
            exit 1
            ;;
    esac

    if [[ "$multi_az" == "true" ]]; then
        instance_cost=$((instance_cost * 2))
    fi

    local storage_cost=0
    if [[ $storage -gt 20 ]]; then
        storage_cost=$(echo "scale=2; ($storage - 20) * 0.115" | bc)
    fi

    local total_cost=$(echo "scale=2; $instance_cost + $storage_cost" | bc)

    cat << EOF
${PURPLE}PostgreSQL Cost Estimate${NC}

${CYAN}Configuration:${NC}
  Instance:    ${instance_type}
  Multi-AZ:    ${multi_az}
  Storage:     ${storage} GB

${CYAN}Cost Breakdown:${NC}
  Instance:    \$${instance_cost}/month
  Storage:     \$${storage_cost}/month ($([ $storage -le 20 ] && echo "first 20GB included" || echo "$(($storage - 20))GB extra"))
  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  ${GREEN}Total:       ~\$${total_cost}/month${NC}

${CYAN}Annual:${NC}      ~\$$(echo "scale=2; $total_cost * 12" | bc)/year

${YELLOW}Optimization Tips:${NC}
вҖў Use 'small' size in dev environments
вҖў Enable Multi-AZ only for production
вҖў Set up lifecycle policies for automated backups
вҖў Consider Reserved Instances for 30-40% savings

EOF
}

# Cost table for Redis
cost_redis() {
    local size="${1:-}"
    local nodes="${2:-1}"
    local compare="${3:-false}"

    if [[ "$compare" == "true" ]]; then
        cat << EOF
${PURPLE}Redis Cost Comparison${NC}

${CYAN}Single Node:${NC}
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ Size    в”Ӯ Instance         в”Ӯ Monthly Cost   в”Ӯ Best For        в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ small   в”Ӯ cache.t3.micro   в”Ӯ ~\$10/month    в”Ӯ Dev/Test        в”Ӯ
в”Ӯ medium  в”Ӯ cache.t3.small   в”Ӯ ~\$25/month    в”Ӯ Staging         в”Ӯ
в”Ӯ large   в”Ӯ cache.t3.medium  в”Ӯ ~\$50/month    в”Ӯ Production      в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

${CYAN}High Availability (2+ nodes):${NC}
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ Size    в”Ӯ Nodes в”Ӯ Monthly Cost   в”Ӯ Configuration           в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ small   в”Ӯ 2     в”Ӯ ~\$20/month    в”Ӯ Dev HA                  в”Ӯ
в”Ӯ medium  в”Ӯ 2     в”Ӯ ~\$50/month    в”Ӯ Staging/Prod            в”Ӯ
в”Ӯ medium  в”Ӯ 3     в”Ӯ ~\$75/month    в”Ӯ Prod + Read Replicas    в”Ӯ
в”Ӯ large   в”Ӯ 2     в”Ӯ ~\$100/month   в”Ӯ High-Traffic Prod       в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

${CYAN}Additional Costs:${NC}
вҖў Snapshots: \$0.085/GB/month
вҖў Data Transfer: \$0.09/GB outbound
вҖў Encryption: Included (no extra cost)

EOF
        return
    fi

    local per_node_cost=0
    local instance_type=""

    case "$size" in
        small)
            per_node_cost=10
            instance_type="cache.t3.micro"
            ;;
        medium)
            per_node_cost=25
            instance_type="cache.t3.small"
            ;;
        large)
            per_node_cost=50
            instance_type="cache.t3.medium"
            ;;
        *)
            echo "Invalid size. Use: small, medium, large"
            exit 1
            ;;
    esac

    local total_cost=$((per_node_cost * nodes))

    cat << EOF
${PURPLE}Redis Cost Estimate${NC}

${CYAN}Configuration:${NC}
  Instance:    ${instance_type}
  Nodes:       ${nodes}
  Failover:    $([ $nodes -gt 1 ] && echo "Enabled (HA)" || echo "Disabled")

${CYAN}Cost Breakdown:${NC}
  Per Node:    \$${per_node_cost}/month
  Nodes:       ${nodes} Г— \$${per_node_cost}
  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  ${GREEN}Total:       ~\$${total_cost}/month${NC}

${CYAN}Annual:${NC}      ~\$$(echo "scale=2; $total_cost * 12" | bc)/year

${YELLOW}Optimization Tips:${NC}
вҖў Use single node in dev (${nodes} вҶ’ 1 saves \$$(( (nodes - 1) * per_node_cost ))/month)
вҖў Enable automatic failover only in staging/prod
вҖў Use smaller instances with more nodes for better HA
вҖў Consider Reserved Nodes for 30% savings

EOF
}

# Cost table for S3
cost_s3bucket() {
    cat << EOF
${PURPLE}S3 Object Storage Cost Estimate${NC}

${CYAN}Pricing Model:${NC} Pay-as-you-go (usage-based)

${CYAN}Storage Costs:${NC}
  Standard:            \$0.023/GB/month
  Infrequent Access:   \$0.0125/GB/month (after 30 days)
  Glacier:             \$0.004/GB/month (after 90 days)

${CYAN}Request Costs:${NC}
  PUT/POST:            \$0.005 per 1,000 requests
  GET/SELECT:          \$0.0004 per 1,000 requests

${CYAN}Data Transfer:${NC}
  Inbound:             Free
  Outbound (first 1GB): Free
  Outbound (next 9.99TB): \$0.09/GB

${CYAN}Typical Monthly Costs:${NC}
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ Usage            в”Ӯ Storage        в”Ӯ Est. Cost       в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ Small app        в”Ӯ 10 GB          в”Ӯ ~\$1/month      в”Ӯ
в”Ӯ Medium app       в”Ӯ 100 GB         в”Ӯ ~\$3/month      в”Ӯ
в”Ӯ Large app        в”Ӯ 1 TB           в”Ӯ ~\$25/month     в”Ӯ
в”Ӯ With lifecycle   в”Ӯ 1 TB вҶ’ Glacier в”Ӯ ~\$8/month      в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

${CYAN}Lifecycle Optimization:${NC}
  Days 0-30:    Standard Storage    \$23/TB/month
  Days 31-90:   Infrequent Access   \$12.50/TB/month
  Days 90+:     Glacier             \$4/TB/month

  ${GREEN}Average with lifecycle: ~\$8/TB/month (65% savings)${NC}

${YELLOW}Optimization Tips:${NC}
вҖў Enable lifecycle policies (automatic cost reduction)
вҖў Use Intelligent-Tiering for unpredictable access patterns
вҖў Enable versioning only when needed
вҖў Set up expiration rules for temporary data
вҖў Use CloudFront for high-traffic public content

EOF
}

# Main
main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 1
    fi

    local type="$1"
    shift

    # SECURITY: Validate type format to prevent command injection
    if [[ ! "$type" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
        error "Invalid type: ${type}"
        exit 1
    fi

    local size="medium"
    local multi_az="false"
    local nodes="1"
    local storage="20"
    local compare="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --size=*) size="${1#*=}" ;;
            --multi-az) multi_az="true" ;;
            --nodes=*) nodes="${1#*=}" ;;
            --storage=*) storage="${1#*=}" ;;
            --compare) compare="true" ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                exit 1
                ;;
        esac
        shift
    done

    # SECURITY: Validate size parameter
    if [[ -n "$size" ]] && ! validate_size "$size"; then
        exit 1
    fi

    # SECURITY: Validate storage parameter (must be integer)
    if [[ -n "$storage" ]] && ! validate_storage "$storage"; then
        exit 1
    fi

    # SECURITY: Validate nodes parameter (must be integer 1-10)
    if [[ -n "$nodes" ]] && [[ ! "$nodes" =~ ^[0-9]+$ ]]; then
        error "Invalid nodes value: ${nodes} (must be a number)"
        exit 1
    fi
    if [[ -n "$nodes" ]] && (( nodes < 1 || nodes > 10 )); then
        error "Invalid nodes value: ${nodes} (must be between 1 and 10)"
        exit 1
    fi

    case "$type" in
        postgres|postgresql)
            cost_postgres "$size" "$multi_az" "$storage" "$compare"
            ;;
        redis)
            cost_redis "$size" "$nodes" "$compare"
            ;;
        s3|s3bucket)
            cost_s3bucket
            ;;
        *)
            echo "Unknown type: ${type}"
            echo "Supported types: postgres, redis, s3bucket"
            exit 1
            ;;
    esac
}

main "$@"
