#!/usr/bin/env bash
# ABOUTME: Platform create command - generate infrastructure claims with validation
# ABOUTME: Interactive creation with smart defaults, cost estimation, and GitOps integration

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source secure validation functions
# shellcheck source=./platform-validation.sh
source "${SCRIPT_DIR}/platform-validation.sh"

# Helper functions
info() { echo -e "${BLUE}ℹ${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

usage() {
    cat << EOF
Usage: platform create <type> <name> [options]

Create a new infrastructure claim with validation and cost estimation.

${CYAN}Arguments:${NC}
  type                Infrastructure type (postgres, redis, s3bucket)
  name                Resource name (lowercase, alphanumeric, hyphens)

${CYAN}Options:${NC}
  --env=ENV           Environment (dev, staging, production) [required]
  --size=SIZE         Instance size (small, medium, large)
  --dry-run           Generate YAML without creating
  --auto-commit       Automatically commit to git
  --skip-cost         Skip cost estimation

${CYAN}PostgreSQL Options:${NC}
  --version=VER       Engine version (default: 15.3)
  --storage=GB        Storage in GB (default: 20)
  --multi-az          Enable multi-AZ deployment
  --backup-days=N     Backup retention days (default: 7)

${CYAN}Redis Options:${NC}
  --version=VER       Engine version (default: 7.0)
  --nodes=N           Number of nodes (default: 1)
  --auto-failover     Enable automatic failover

${CYAN}S3 Bucket Options:${NC}
  --versioning        Enable versioning (default: true)
  --lifecycle         Enable lifecycle policies
  --public            Allow public access (not recommended)

${CYAN}Examples:${NC}
  # Create dev PostgreSQL database
  platform create postgres my-db --size=small --env=dev

  # Create staging Redis with HA
  platform create redis my-cache --size=medium --nodes=2 --auto-failover --env=staging

  # Create production S3 bucket
  platform create s3bucket my-storage --env=production

  # Dry run (preview only)
  platform create postgres test-db --size=large --env=dev --dry-run

EOF
}

# Calculate cost estimate
estimate_cost() {
    local type="$1"
    local size="${2:-small}"
    local multi_az="${3:-false}"
    local nodes="${4:-1}"

    case "$type" in
        postgres)
            case "$size" in
                small)
                    if [[ "$multi_az" == "true" ]]; then
                        echo "~\$30/month (Multi-AZ)"
                    else
                        echo "~\$15/month"
                    fi
                    ;;
                medium)
                    if [[ "$multi_az" == "true" ]]; then
                        echo "~\$60/month (Multi-AZ)"
                    else
                        echo "~\$30/month"
                    fi
                    ;;
                large)
                    if [[ "$multi_az" == "true" ]]; then
                        echo "~\$120/month (Multi-AZ)"
                    else
                        echo "~\$60/month"
                    fi
                    ;;
            esac
            ;;
        redis)
            local base_cost=0
            case "$size" in
                small) base_cost=10 ;;
                medium) base_cost=25 ;;
                large) base_cost=50 ;;
            esac
            local total=$((base_cost * nodes))
            echo "~\$${total}/month (${nodes} nodes)"
            ;;
        s3bucket)
            echo "~\$1-10/month (usage-based)"
            ;;
    esac
}

# Generate PostgreSQL claim
generate_postgres() {
    local name="$1"
    local env="$2"
    local size="${3:-small}"
    local version="${4:-15.3}"
    local storage="${5:-20}"
    local multi_az="${6:-false}"
    local backup_days="${7:-1}"

    # Adjust defaults based on environment
    if [[ "$env" == "production" ]]; then
        multi_az="${multi_az:-true}"
        backup_days="${backup_days:-30}"
    elif [[ "$env" == "staging" ]]; then
        backup_days="${backup_days:-7}"
    fi

    cat << EOF
# ABOUTME: ${env^} PostgreSQL database claim - auto-generated by platform CLI
# ABOUTME: Size: ${size}, Multi-AZ: ${multi_az}, Backups: ${backup_days} days

apiVersion: platform.io/v1alpha1
kind: PostgreSQL
metadata:
  name: ${name}
  namespace: ${env}
  labels:
    app: ${name}
    environment: ${env}
    managed-by: platform-cli
  annotations:
    platform.io/created-by: "platform-cli"
    platform.io/created-at: "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
spec:
  parameters:
    # Instance configuration
    size: ${size}
    engineVersion: "${version}"
    storageGB: ${storage}

    # High availability
    multiAZ: ${multi_az}

    # Backup configuration
    backupRetentionDays: ${backup_days}

    # Network configuration
    networkConfig:
      publiclyAccessible: false
      allowedCIDRs:
        - "10.0.0.0/8"

    # Provider
    provider: aws
    region: eu-west-1

  # Connection secret
  writeConnectionSecretToRef:
    name: ${name}-connection
EOF
}

# Generate Redis claim
generate_redis() {
    local name="$1"
    local env="$2"
    local size="${3:-small}"
    local version="${4:-7.0}"
    local nodes="${5:-1}"
    local auto_failover="${6:-false}"
    local snapshot_days="${7:-3}"

    # Adjust defaults based on environment
    if [[ "$env" == "production" ]]; then
        nodes="${nodes:-2}"
        auto_failover="true"
        snapshot_days="${snapshot_days:-7}"
    elif [[ "$env" == "staging" ]]; then
        nodes="${nodes:-2}"
        auto_failover="${auto_failover:-true}"
    fi

    cat << EOF
# ABOUTME: ${env^} Redis cache claim - auto-generated by platform CLI
# ABOUTME: Size: ${size}, Nodes: ${nodes}, Auto-failover: ${auto_failover}

apiVersion: platform.io/v1alpha1
kind: Redis
metadata:
  name: ${name}
  namespace: ${env}
  labels:
    app: ${name}
    environment: ${env}
    managed-by: platform-cli
  annotations:
    platform.io/created-by: "platform-cli"
    platform.io/created-at: "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
spec:
  parameters:
    # Instance configuration
    size: ${size}
    engineVersion: "${version}"

    # High availability
    numNodes: ${nodes}
    automaticFailover: ${auto_failover}

    # Security
    transitEncryption: true
    atRestEncryption: true
    authTokenEnabled: true

    # Snapshots
    snapshotRetentionDays: ${snapshot_days}
    snapshotWindow: "03:00-05:00"

    # Network configuration
    networkConfig:
      allowedCIDRs:
        - "10.0.0.0/8"

    # Provider
    provider: aws
    region: eu-west-1

  # Connection secret
  writeConnectionSecretToRef:
    name: ${name}-connection
EOF
}

# Generate S3 Bucket claim
generate_s3bucket() {
    local name="$1"
    local env="$2"
    local versioning="${3:-true}"
    local lifecycle="${4:-false}"
    local public="${5:-false}"

    # Production defaults
    if [[ "$env" == "production" ]]; then
        versioning="true"
        lifecycle="true"
        public="false"
    fi

    cat << EOF
# ABOUTME: ${env^} S3 bucket claim - auto-generated by platform CLI
# ABOUTME: Versioning: ${versioning}, Lifecycle: ${lifecycle}, Public: ${public}

apiVersion: platform.io/v1alpha1
kind: S3Bucket
metadata:
  name: ${name}
  namespace: ${env}
  labels:
    app: ${name}
    environment: ${env}
    managed-by: platform-cli
  annotations:
    platform.io/created-by: "platform-cli"
    platform.io/created-at: "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
spec:
  parameters:
    # Versioning
    versioning: ${versioning}

    # Security
    encryption: AES256
    blockPublicAccess: $([ "$public" == "true" ] && echo "false" || echo "true")

    # Lifecycle policies
EOF

    if [[ "$lifecycle" == "true" ]]; then
        cat << EOF
    lifecycleRules:
      enabled: true
      transitionToIA: 30
      transitionToGlacier: 90
      expireDays: 365

EOF
    fi

    cat << EOF
    # Provider
    provider: aws
    region: eu-west-1

  # Connection secret
  writeConnectionSecretToRef:
    name: ${name}-connection
EOF
}

# Main
main() {
    if [[ $# -lt 2 ]]; then
        usage
        exit 1
    fi

    local type="$1"
    local name="$2"
    shift 2

    # Parse options
    local env=""
    local size="small"
    local version=""
    local storage="20"
    local multi_az="false"
    local backup_days="1"
    local nodes="1"
    local auto_failover="false"
    local snapshot_days="3"
    local versioning="true"
    local lifecycle="false"
    local public="false"
    local dry_run="false"
    local auto_commit="false"
    local skip_cost="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env=*) env="${1#*=}" ;;
            --size=*) size="${1#*=}" ;;
            --version=*) version="${1#*=}" ;;
            --storage=*) storage="${1#*=}" ;;
            --multi-az) multi_az="true" ;;
            --backup-days=*) backup_days="${1#*=}" ;;
            --nodes=*) nodes="${1#*=}" ;;
            --auto-failover) auto_failover="true" ;;
            --snapshot-days=*) snapshot_days="${1#*=}" ;;
            --versioning) versioning="true" ;;
            --lifecycle) lifecycle="true" ;;
            --public) public="true" ;;
            --dry-run) dry_run="true" ;;
            --auto-commit) auto_commit="true" ;;
            --skip-cost) skip_cost="true" ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                error "Unknown option: $1"
                exit 1
                ;;
        esac
        shift
    done

    # Validate inputs (SECURITY: Prevent command injection)
    if [[ -z "$env" ]]; then
        error "Environment is required. Use --env=dev|staging|production"
        exit 1
    fi

    # Validate name (prevents path traversal and command injection)
    if ! validate_name "$name"; then
        exit 1
    fi

    # Validate environment
    if ! validate_env "$env"; then
        exit 1
    fi

    # Validate size
    if ! validate_size "$size"; then
        exit 1
    fi

    # Validate storage (if applicable)
    if [[ -n "$storage" ]]; then
        if ! validate_storage "$storage"; then
            exit 1
        fi
    fi

    # Generate YAML
    info "Validating claim..."
    success "Name '${name}' is valid"
    success "Environment '${env}' is valid"
    success "Size '${size}' is valid"

    # Cost estimation
    if [[ "$skip_cost" != "true" ]]; then
        local cost=$(estimate_cost "$type" "$size" "$multi_az" "$nodes")
        echo ""
        echo -e "${CYAN}💰 Cost Estimate:${NC} ${cost}"
        echo ""
    fi

    # Generate claim
    info "Generating claim..."

    # SECURITY: Validate file path to prevent path traversal
    local relative_path="environments/${env}/${name}.yaml"
    if ! validate_file_path "$relative_path" "$PROJECT_ROOT"; then
        error "File path validation failed"
        exit 1
    fi

    local output_file="${PROJECT_ROOT}/${relative_path}"
    local yaml_content=""

    case "$type" in
        postgres|postgresql)
            [[ -z "$version" ]] && version="15.3"
            yaml_content=$(generate_postgres "$name" "$env" "$size" "$version" "$storage" "$multi_az" "$backup_days")
            ;;
        redis)
            [[ -z "$version" ]] && version="7.0"
            yaml_content=$(generate_redis "$name" "$env" "$size" "$version" "$nodes" "$auto_failover" "$snapshot_days")
            ;;
        s3|s3bucket)
            yaml_content=$(generate_s3bucket "$name" "$env" "$versioning" "$lifecycle" "$public")
            ;;
        *)
            error "Unknown type: ${type}"
            echo "Supported types: postgres, redis, s3bucket"
            exit 1
            ;;
    esac

    # Show preview
    echo ""
    echo -e "${PURPLE}📄 Generated Claim:${NC}"
    echo "────────────────────────────────────────"
    echo "$yaml_content"
    echo "────────────────────────────────────────"
    echo ""

    if [[ "$dry_run" == "true" ]]; then
        warn "Dry run mode - no files created"
        exit 0
    fi

    # Confirm
    if [[ "$auto_commit" != "true" ]]; then
        read -p "Create this claim? [Y/n] " -n 1 -r
        echo ""
        if [[ ! $REPLY =~ ^[Yy]$ ]] && [[ -n $REPLY ]]; then
            warn "Cancelled"
            exit 0
        fi
    fi

    # Write file
    echo "$yaml_content" > "$output_file"
    success "Created: ${output_file}"

    # Git operations
    if [[ "$auto_commit" == "true" ]]; then
        cd "$PROJECT_ROOT"
        git add "$output_file"
        git commit -m "feat: Add ${type} ${name} to ${env} environment

Created via platform CLI with:
- Size: ${size}
- Environment: ${env}
- Auto-generated configuration

🤖 Generated with Platform CLI"
        success "Committed to git"
    else
        echo ""
        info "Next steps:"
        echo "  1. Review the claim: cat ${output_file}"
        echo "  2. Commit to git:"
        echo "     git add ${output_file}"
        echo "     git commit -m 'feat: Add ${type} ${name}'"
        echo "     git push"
        echo "  3. Check status:"
        echo "     platform status ${type} ${name} --env=${env}"
    fi

    echo ""
    success "Done! Infrastructure will be provisioned via GitOps"
}

main "$@"
