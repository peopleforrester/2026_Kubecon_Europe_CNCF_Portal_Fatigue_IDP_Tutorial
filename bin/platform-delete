#!/usr/bin/env bash
# ABOUTME: Platform delete command - safely remove infrastructure claims
# ABOUTME: Deletes claim files and optionally the provisioned resources

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source secure validation functions
# shellcheck source=./platform-validation.sh
source "${SCRIPT_DIR}/platform-validation.sh"

usage() {
    cat << EOF
Usage: platform delete <type> <name> --env=<environment>

Delete infrastructure claims and optionally the provisioned resources.

${CYAN}Arguments:${NC}
  type                Infrastructure type (postgres, redis, s3bucket)
  name                Resource name
  --env=ENV           Environment (dev, staging, production)

${CYAN}Options:${NC}
  --force             Skip confirmation prompt
  --keep-data         Keep the cloud resource (delete claim only)
  --auto-commit       Automatically commit deletion to git

${CYAN}Examples:${NC}
  # Delete with confirmation
  platform delete postgres my-db --env=dev

  # Delete without confirmation (be careful!)
  platform delete redis my-cache --env=staging --force

  # Delete claim but keep the resource
  platform delete postgres my-db --env=dev --keep-data

${RED}WARNING:${NC} This will delete infrastructure and may cause data loss!

EOF
}

# Main
main() {
    if [[ $# -lt 3 ]]; then
        usage
        exit 1
    fi

    local type="$1"
    local name="$2"
    shift 2

    local env=""
    local force="false"
    local keep_data="false"
    local auto_commit="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env=*) env="${1#*=}" ;;
            --force) force="true" ;;
            --keep-data) keep_data="true" ;;
            --auto-commit) auto_commit="true" ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                exit 1
                ;;
        esac
        shift
    done

    if [[ -z "$env" ]]; then
        error "Environment is required: --env=dev|staging|production"
        exit 1
    fi

    # SECURITY: CRITICAL - Validate inputs to prevent path traversal and command injection
    if ! validate_name "$name"; then
        exit 1
    fi

    if ! validate_env "$env"; then
        exit 1
    fi

    # Validate type format
    if [[ ! "$type" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
        error "Invalid type: ${type}"
        exit 1
    fi

    # SECURITY: Validate file path to prevent path traversal
    local relative_path="environments/${env}/${name}.yaml"
    if ! validate_file_path "$relative_path"; then
        error "File path validation failed"
        exit 1
    fi

    local file_path="$relative_path"

    # Check if file exists
    if [[ ! -f "$file_path" ]]; then
        echo -e "${RED}✗${NC} Claim file not found: ${file_path}"
        echo ""
        echo "Available claims in ${env}:"
        ls -1 "environments/${env}/"*.yaml 2>/dev/null || echo "  (none)"
        exit 1
    fi

    # Show what will be deleted
    echo -e "${YELLOW}⚠${NC}  ${RED}Deletion Request${NC}"
    echo ""
    echo -e "${CYAN}Type:${NC}        ${type}"
    echo -e "${CYAN}Name:${NC}        ${name}"
    echo -e "${CYAN}Environment:${NC} ${env}"
    echo -e "${CYAN}File:${NC}        ${file_path}"
    echo ""

    if [[ "$keep_data" == "true" ]]; then
        echo -e "${BLUE}Mode:${NC}        Delete claim file only (keep cloud resource)"
        echo ""
        echo "This will:"
        echo "  • Remove the claim file from Git"
        echo "  • Orphan the cloud resource (manual cleanup required)"
    else
        echo -e "${RED}Mode:${NC}        Delete claim AND cloud resource"
        echo ""
        echo -e "${RED}This will:${NC}"
        echo "  • Delete the claim file from Git"
        echo "  • Trigger ArgoCD to remove the claim from cluster"
        echo "  • Crossplane will DELETE the cloud resource"
        echo ""
        echo -e "${RED}⚠  DATA LOSS WARNING:${NC}"
        case "$type" in
            postgres|postgresql)
                echo "  • PostgreSQL database will be DELETED"
                echo "  • All data will be PERMANENTLY LOST"
                echo "  • Final snapshot may be taken (check RDS settings)"
                ;;
            redis)
                echo "  • Redis cache will be DELETED"
                echo "  • All cached data will be LOST"
                echo "  • Final snapshot may be taken (check settings)"
                ;;
            s3|s3bucket)
                echo "  • S3 bucket will be DELETED"
                echo "  • All objects will be PERMANENTLY DELETED"
                echo "  • Versioned objects may be retained (check settings)"
                ;;
        esac
    fi

    echo ""

    # Confirmation
    if [[ "$force" != "true" ]]; then
        echo -e "${RED}Are you absolutely sure?${NC}"
        read -p "Type the resource name '${name}' to confirm: " -r confirm
        if [[ "$confirm" != "$name" ]]; then
            echo ""
            echo -e "${BLUE}Cancelled${NC} - deletion aborted"
            exit 0
        fi

        if [[ "$keep_data" != "true" ]]; then
            echo ""
            read -p "Type 'DELETE' in all caps to proceed: " -r final_confirm
            if [[ "$final_confirm" != "DELETE" ]]; then
                echo ""
                echo -e "${BLUE}Cancelled${NC} - deletion aborted"
                exit 0
            fi
        fi
    fi

    echo ""
    echo -e "${BLUE}Processing deletion...${NC}"

    # Delete the file
    if rm "$file_path"; then
        echo -e "${GREEN}✓${NC} Removed claim file: ${file_path}"
    else
        echo -e "${RED}✗${NC} Failed to remove file: ${file_path}"
        exit 1
    fi

    # Git operations
    if [[ "$auto_commit" == "true" ]]; then
        git add "$file_path"
        local commit_msg="chore: Delete ${type} ${name} from ${env}"
        if [[ "$keep_data" == "true" ]]; then
            commit_msg="${commit_msg} (keep data)"
        fi
        git commit -m "${commit_msg}

🤖 Generated with Platform CLI"
        echo -e "${GREEN}✓${NC} Committed to git"
    else
        echo ""
        echo -e "${CYAN}Next steps:${NC}"
        echo "  1. Commit deletion:"
        echo "     git add ${file_path}"
        echo "     git commit -m 'chore: Delete ${type} ${name}'"
        echo "     git push"
        if [[ "$keep_data" != "true" ]]; then
            echo ""
            echo "  2. Monitor deletion:"
            echo "     kubectl get ${type,,} -n ${env}"
            echo ""
            echo -e "${YELLOW}Note:${NC} Cloud resource deletion may take 5-10 minutes"
        fi
    fi

    echo ""
    if [[ "$keep_data" == "true" ]]; then
        echo -e "${GREEN}✓${NC} Claim deleted (cloud resource preserved)"
        echo ""
        echo -e "${YELLOW}Manual cleanup required:${NC}"
        echo "  • The cloud resource still exists and is BILLING"
        echo "  • Delete manually via AWS Console or:"
        echo "    kubectl delete ${type,,} ${name} -n ${env}"
    else
        echo -e "${GREEN}✓${NC} Deletion initiated"
        echo ""
        echo -e "${YELLOW}What happens next:${NC}"
        echo "  1. ArgoCD detects file removal (within 3 min)"
        echo "  2. Crossplane deletes cloud resource (5-10 min)"
        echo "  3. Connection secrets are removed"
        echo "  4. Billing stops"
    fi
}

main "$@"
