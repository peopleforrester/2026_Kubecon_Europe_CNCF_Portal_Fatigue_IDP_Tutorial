#!/usr/bin/env bash
# ABOUTME: Platform connect command - retrieve connection details
# ABOUTME: Shows credentials and connection strings for provisioned resources

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
NC='\033[0m'

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source secure validation functions
# shellcheck source=./platform-validation.sh
source "${SCRIPT_DIR}/platform-validation.sh"

usage() {
    cat << EOF
Usage: platform connect <type> <name> --env=<environment>

Get connection details for provisioned infrastructure.

${CYAN}Arguments:${NC}
  type                Infrastructure type (postgres, redis, s3bucket)
  name                Resource name
  --env=ENV           Environment (dev, staging, production)

${CYAN}Options:${NC}
  --format=FORMAT     Output format (env, json, yaml, url)
  --show-password     Display password (default: masked)
  --export            Export as environment variables

${CYAN}Examples:${NC}
  # Get connection details
  platform connect postgres my-db --env=dev

  # Export as env vars
  platform connect postgres my-db --env=dev --format=env --export

  # Get connection URL
  platform connect postgres my-db --env=dev --format=url

  # JSON format (for scripts)
  platform connect redis my-cache --env=staging --format=json

EOF
}

# Main
main() {
    if [[ $# -lt 3 ]]; then
        usage
        exit 1
    fi

    local type="$1"
    local name="$2"
    shift 2

    local env=""
    local format="table"
    local show_password="false"
    local export_vars="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env=*) env="${1#*=}" ;;
            --format=*) format="${1#*=}" ;;
            --show-password) show_password="true" ;;
            --export) export_vars="true" ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                exit 1
                ;;
        esac
        shift
    done

    if [[ -z "$env" ]]; then
        error "Environment is required: --env=dev|staging|production"
        exit 1
    fi

    # SECURITY: Validate all user inputs to prevent command injection
    if ! validate_name "$name"; then
        exit 1
    fi

    if ! validate_env "$env"; then
        exit 1
    fi

    # Validate type format
    if [[ ! "$type" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
        error "Invalid type: ${type}"
        exit 1
    fi

    local secret_name="${name}-connection"

    # Check kubectl
    if ! command -v kubectl &> /dev/null; then
        echo -e "${RED}✗${NC} kubectl not found"
        echo ""
        echo "Manual check:"
        echo "  kubectl get secret ${secret_name} -n ${env} -o yaml"
        exit 1
    fi

    # Check if secret exists
    if ! kubectl get secret "${secret_name}" -n "${env}" &> /dev/null; then
        echo -e "${RED}✗${NC} Connection secret not found: ${secret_name}"
        echo ""
        echo "Possible reasons:"
        echo "  • Resource not yet provisioned (check: platform status ${type} ${name} --env=${env})"
        echo "  • Secret name mismatch"
        echo "  • Namespace doesn't exist"
        exit 1
    fi

    # Get connection details based on type
    case "$type" in
        postgres|postgresql)
            show_postgres_connection "$secret_name" "$env" "$format" "$show_password" "$export_vars"
            ;;
        redis)
            show_redis_connection "$secret_name" "$env" "$format" "$show_password" "$export_vars"
            ;;
        s3|s3bucket)
            show_s3_connection "$secret_name" "$env" "$format" "$show_password" "$export_vars"
            ;;
        *)
            echo "Unknown type: ${type}"
            exit 1
            ;;
    esac
}

show_postgres_connection() {
    local secret="$1"
    local env="$2"
    local format="$3"
    local show_pass="$4"
    local export_vars="$5"

    local endpoint=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.endpoint}' | base64 -d 2>/dev/null || echo "")
    local port=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.port}' | base64 -d 2>/dev/null || echo "5432")
    local username=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.username}' | base64 -d 2>/dev/null || echo "")
    local password=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.password}' | base64 -d 2>/dev/null || echo "")
    local database=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.database}' | base64 -d 2>/dev/null || echo "postgres")

    local masked_password="********"
    [[ "$show_pass" == "true" ]] && masked_password="$password"

    case "$format" in
        table)
            cat << EOF
${PURPLE}PostgreSQL Connection Details${NC}

${CYAN}Connection:${NC}
  Host:        ${endpoint}
  Port:        ${port}
  Database:    ${database}
  Username:    ${username}
  Password:    ${masked_password}

${CYAN}Connection String:${NC}
  postgresql://${username}:${masked_password}@${endpoint}:${port}/${database}

${CYAN}Usage in Application:${NC}
  env:
  - name: DB_HOST
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: endpoint
  - name: DB_PORT
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: port
  - name: DB_USER
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: username
  - name: DB_PASSWORD
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: password
  - name: DB_NAME
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: database

${YELLOW}Tip:${NC} Use --show-password to reveal password
${YELLOW}Tip:${NC} Use --format=env to export as environment variables
EOF
            ;;
        env)
            if [[ "$export_vars" == "true" ]]; then
                cat << EOF
export DB_HOST="${endpoint}"
export DB_PORT="${port}"
export DB_USER="${username}"
export DB_PASSWORD="${password}"
export DB_NAME="${database}"
export DATABASE_URL="postgresql://${username}:${password}@${endpoint}:${port}/${database}"
EOF
            else
                cat << EOF
DB_HOST=${endpoint}
DB_PORT=${port}
DB_USER=${username}
DB_PASSWORD=${masked_password}
DB_NAME=${database}
DATABASE_URL=postgresql://${username}:${masked_password}@${endpoint}:${port}/${database}
EOF
            fi
            ;;
        url)
            echo "postgresql://${username}:${password}@${endpoint}:${port}/${database}"
            ;;
        json)
            cat << EOF
{
  "host": "${endpoint}",
  "port": ${port},
  "username": "${username}",
  "password": "${password}",
  "database": "${database}",
  "url": "postgresql://${username}:${password}@${endpoint}:${port}/${database}"
}
EOF
            ;;
        yaml)
            cat << EOF
host: ${endpoint}
port: ${port}
username: ${username}
password: ${password}
database: ${database}
url: postgresql://${username}:${password}@${endpoint}:${port}/${database}
EOF
            ;;
    esac
}

show_redis_connection() {
    local secret="$1"
    local env="$2"
    local format="$3"
    local show_pass="$4"
    local export_vars="$5"

    local endpoint=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.endpoint}' | base64 -d 2>/dev/null || echo "")
    local port=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.port}' | base64 -d 2>/dev/null || echo "6379")
    local auth_token=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.auth-token}' | base64 -d 2>/dev/null || echo "")

    local masked_token="********"
    [[ "$show_pass" == "true" ]] && masked_token="$auth_token"

    case "$format" in
        table)
            cat << EOF
${PURPLE}Redis Connection Details${NC}

${CYAN}Connection:${NC}
  Host:        ${endpoint}
  Port:        ${port}
  Auth Token:  ${masked_token}

${CYAN}Connection String:${NC}
  redis://:${masked_token}@${endpoint}:${port}

${CYAN}Usage in Application:${NC}
  env:
  - name: REDIS_HOST
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: endpoint
  - name: REDIS_PORT
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: port
  - name: REDIS_AUTH_TOKEN
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: auth-token

${YELLOW}Tip:${NC} Use --show-password to reveal auth token
EOF
            ;;
        env)
            if [[ "$export_vars" == "true" ]]; then
                echo "export REDIS_HOST=\"${endpoint}\""
                echo "export REDIS_PORT=\"${port}\""
                echo "export REDIS_AUTH_TOKEN=\"${auth_token}\""
                echo "export REDIS_URL=\"redis://:${auth_token}@${endpoint}:${port}\""
            else
                echo "REDIS_HOST=${endpoint}"
                echo "REDIS_PORT=${port}"
                echo "REDIS_AUTH_TOKEN=${masked_token}"
            fi
            ;;
        url)
            echo "redis://:${auth_token}@${endpoint}:${port}"
            ;;
        json)
            cat << EOF
{
  "host": "${endpoint}",
  "port": ${port},
  "auth_token": "${auth_token}",
  "url": "redis://:${auth_token}@${endpoint}:${port}"
}
EOF
            ;;
    esac
}

show_s3_connection() {
    local secret="$1"
    local env="$2"
    local format="$3"
    local show_pass="$4"
    local export_vars="$5"

    local bucket=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.bucket-name}' | base64 -d 2>/dev/null || echo "")
    local region=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.region}' | base64 -d 2>/dev/null || echo "us-west-2")
    local endpoint=$(kubectl get secret "$secret" -n "$env" -o jsonpath='{.data.endpoint}' | base64 -d 2>/dev/null || echo "s3.${region}.amazonaws.com")

    case "$format" in
        table)
            cat << EOF
${PURPLE}S3 Bucket Connection Details${NC}

${CYAN}Bucket:${NC}
  Name:        ${bucket}
  Region:      ${region}
  Endpoint:    ${endpoint}

${CYAN}AWS CLI Usage:${NC}
  aws s3 ls s3://${bucket}/
  aws s3 cp myfile.txt s3://${bucket}/

${CYAN}Usage in Application:${NC}
  env:
  - name: S3_BUCKET
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: bucket-name
  - name: S3_REGION
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: region
  - name: S3_ENDPOINT
    valueFrom:
      secretKeyRef:
        name: ${secret}
        key: endpoint

${YELLOW}Note:${NC} AWS credentials must be provided separately (via IAM role or secret)
EOF
            ;;
        env)
            if [[ "$export_vars" == "true" ]]; then
                echo "export S3_BUCKET=\"${bucket}\""
                echo "export S3_REGION=\"${region}\""
                echo "export S3_ENDPOINT=\"${endpoint}\""
            else
                echo "S3_BUCKET=${bucket}"
                echo "S3_REGION=${region}"
                echo "S3_ENDPOINT=${endpoint}"
            fi
            ;;
        json)
            cat << EOF
{
  "bucket": "${bucket}",
  "region": "${region}",
  "endpoint": "${endpoint}"
}
EOF
            ;;
    esac
}

main "$@"
